<section class="ds-traits">
  <details class="ds-ability-group" open>
    <summary class="ds-ability-group-title ds-section-title">
      <i class="ds-group-chevron fa-solid fa-chevron-down"></i>
      Traits
    </summary>
  {{#each features}}
    <div class="ds-trait" data-item-id="{{this.id}}">
      <div class="ds-trait-head">
        <span class="ds-trait-name"
              data-action="edit"
              data-item-id="{{this.id}}"
              data-tooltip="Open {{this.name}}">{{this.name}}</span>
      </div>
      {{#if enrichedDescription}}
        <div class="ds-trait-body">{{{enrichedDescription}}}</div>
      {{/if}}
    </div>
  {{/each}}
  {{#each effects}}
    <div class="ds-trait ds-trait-effect {{#unless this.active}}ds-trait-disabled{{/unless}}"
         data-effect-id="{{this.id}}">
      <div class="ds-trait-head">
        <input type="checkbox"
               class="ds-trait-toggle"
               data-action="toggleEffect"
               data-effect-id="{{this.id}}"
               {{#unless this.disabled}}checked{{/unless}}
               data-tooltip="Enable/disable effect" />
        <span class="ds-trait-name"
              data-action="viewEffect"
              data-effect-id="{{this.id}}"
              data-tooltip="Open {{this.name}}">{{this.name}}</span>
        <span class="ds-trait-source" data-tooltip="Active Effect">
          <i class="fa-solid fa-sparkles"></i>
        </span>
        <button class="ds-trait-delete"
                data-action="deleteEffect"
                data-effect-id="{{this.id}}"
                data-tooltip="Delete {{this.name}}">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
      {{#if enrichedDescription}}
        <div class="ds-trait-body">{{{enrichedDescription}}}</div>
      {{/if}}
    </div>
  {{/each}}
  </details>
</section>
