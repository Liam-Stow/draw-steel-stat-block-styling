<section class="ds-statblock">
  {{> modules/draw-steel-stat-block-styling/templates/partials/header.hbs }}
  {{> modules/draw-steel-stat-block-styling/templates/partials/stats-row.hbs }}
  {{> modules/draw-steel-stat-block-styling/templates/partials/characteristics.hbs }}
  {{> modules/draw-steel-stat-block-styling/templates/partials/resistances.hbs }}

  {{#if features.length}}
    <hr class="ds-divider" />
    <div class="ds-columns">
      {{> modules/draw-steel-stat-block-styling/templates/partials/traits.hbs }}
      {{#if abilities.length}}
        {{> modules/draw-steel-stat-block-styling/templates/partials/abilities.hbs }}
      {{/if}}
    </div>
  {{else if abilities.length}}
    <div class="ds-columns">
      {{> modules/draw-steel-stat-block-styling/templates/partials/abilities.hbs }}
    </div>
  {{/if}}
</section>
